    {
      "cell_type": "code",
      "source": [
        "#Train-Test Split\n",
        "train_model = train.copy()\n",
        "train_model['trainval'] = np.random.rand(len(train_model))\n",
        "train_set = train_model[train_model['trainval'] >= 0.1]\n",
        "val_set = train_model[train_model['trainval'] < 0.9]\n",
        "\n",
        "class Tokenizer:\n",
        "  def __init__(self, max_length = 128):\n",
        "    self.word2id = {}\n",
        "    self.id2word = {}\n",
        "    self.seen = set()\n",
        "    self.max_length = max_length\n",
        "\n",
        "\n",
        "  def fit(self, texts):\n",
        "    vocab = set()\n",
        "    vocab.add('<unk>')\n",
        "    vocab.add('<pad>')\n",
        "    vocab.add('<sos>')\n",
        "    vocab.add('<eos>')\n",
        "    for text in texts:\n",
        "      text.lower()\n",
        "      text = re.sub(r'[^\\w\\s]', '', text)\n",
        "\n",
        "      for word in text.split():\n",
        "        if word in self.seen:\n",
        "          vocab.add(word)\n",
        "\n",
        "        else:\n",
        "          self.seen.add(word)\n",
        "\n",
        "    for index, word in enumerate(vocab):\n",
        "      self.word2id[word] = index\n",
        "      self.id2word[index] = word\n",
        "\n",
        "    self.vocab_size = len(vocab)\n",
        "\n",
        "  def encode(self, text):\n",
        "    text = text.lower()\n",
        "    text = re.sub(r'[^\\w\\s]', '', text)\n",
        "    encoded = []\n",
        "    encoded.append(self.word2id['<sos>'])\n",
        "    index = 0\n",
        "    for word in text.split():\n",
        "      if index == self.max_length-1:\n",
        "        encoded.append(self.word2id['<eos>'])\n",
        "        return encoded #This truncates the sentence\n",
        "      index += 1\n",
        "      try:\n",
        "        encoded.append(self.word2id[word])\n",
        "      except:\n",
        "        word = '<unk>'\n",
        "        encoded.append(self.word2id[word])\n",
        "\n",
        "    encoded.append(self.word2id['<eos>'])\n",
        "    if index < self.max_length-1:\n",
        "      for i in range(index, self.max_length-1):\n",
        "        encoded.append(self.word2id['<pad>'])\n",
        "\n",
        "    return encoded\n",
        "\n",
        "  def decode(self, ids):\n",
        "    decoded = []\n",
        "    for index in encoded:\n",
        "      try:\n",
        "        decoded.append(self.id2word[index])\n",
        "      except:\n",
        "        decoded.append('<unk>')\n",
        "\n",
        "    sequence = \" \".join(decoded)\n",
        "    return sequence\n",
        "\n",
        "\n"
      ],
