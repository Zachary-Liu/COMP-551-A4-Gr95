      }
    },
    {
      "cell_type": "code",
      "source": [
        "dropout = 0.2\n",
        "#pooling = \"last_hidden_state\"\n",
        "#pooling = \"mean_pooling\"\n",
        "#pooling = \"max_pooling\"\n",
        "\n",
        "\n",
        "class LSTMClassifier(nn.Module):\n",
        "  def __init__(self, vocab_size, d_emb, d_hidden, num_layers, dropout, pad_idx, eos_idx, sos_idx, pooling = \"last_hidden_state\"):\n",
        "    super(LSTMClassifier, self).__init__()\n",
        "    self.embedding = nn.Embedding(vocab_size, d_emb)\n",
        "    self.lstm = nn.LSTM(d_emb, d_hidden, num_layers = num_layers, batch_first = False, dropout = dropout, bidirectional = True)\n",
        "    self.pooling = pooling\n",
        "    self.mlp = nn.Linear(d_hidden, 4)\n",
        "  def forward (self, X):\n",
        "    #X is tokenized sequences x Batches\n",
        "    if (not isinstance(X, torch.Tensor)):\n",
        "      X = torch.LongTensor(X).to('cuda')\n",
        "    lengths = ((X != self.pad_idx) & (X!= self.eos_idx)).sum(dim=0)\n",
        "    last_index = lengths - 1\n",
        "    #Embeddings are vectorized sequences x batches x embeddings\n",
        "    embeddings = self.embedding(X)\n",
        "\n",
        "\n",
        "    #Output contains the hidden states of the top LSTM layer at all time steps\n",
        "    #(seq_len, batch_size, hidden_size)\n",
        "    output, (hidden, cell) = self.lstm(embeddings)\n",
        "    batch_size = output.shape[1]\n",
        "    if (self.pooling == \"last_hidden_state\"):\n",
        "      #To find the last hidden state, we should find the item with a blank batch size (check across all batches)\n",
        "      #We find the item at the indexed length\n",
        "      batch_indices = torch.arange(batch_size)\n",
        "      pooled = output[last_index, batch_indices, :]\n",
        "\n",
        "    elif (self.pooling == \"mean_pooling\"):\n",
        "      mask = (X != self.pad_idx) & (X != self.sos_idx) & (X != self.eos_idx)\n",
        "      #Add a dimension to mask at the end -> (seq_len, batch_szie, hidden_size)\n",
        "      mask = mask.unsqueeze(-1)\n",
        "      output_masked = output * mask\n",
        "      mask_sum = output_masked.sum(dim = 0)\n",
        "      pooled = mask_sum/lengths.unsqueeze(-1)\n",
        "\n",
        "    elif (self.pooling == \"max_pooling\"):\n",
        "      mask = (X != self.pad_idx) & (X != self.sos_idx) & (X != self.eos_idx)\n",
        "      mask = mask.unsqueeze(-1)\n",
        "      output_mask = output*mask\n",
        "      mask_max = output_mask.max(dim = 0)\n",
        "      pooled = mask_max[0]\n",
        "\n",
        "    output = self.mlp(pooled)\n",
        "\n",
        "\n",
        "    return output\n",
        "\n",
        "\n"
      ],
